{%- liquid
  assign collection = collections[section.settings.collection]
  if collection == blank
    assign collection = collections.all
  endif
  assign products_to_show = section.settings.products_to_show | default: 4
  assign shown_count = 0
-%}

{%- for product in collection.products -%}
  {%- capture listable -%}{% render 'product-is-listable', product: product %}{%- endcapture -%}
  {%- if listable == 'true' -%}
    {%- assign shown_count = shown_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- if shown_count > 0 -%}
<section class="section section--products" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="block-header{% if section.settings.heading_style == 'curated' %} block-header--center{% else %} block-header--split{% endif %}">
      <h2 class="section-title font-display{% if section.settings.heading_style == 'curated' %} section-title--italic{% endif %}">
        {%- if section.settings.heading != blank -%}
          {{ section.settings.heading }}
        {%- elsif section.settings.heading_style == 'curated' -%}
          {{ 'home.curated_selection' | t }}
        {%- else -%}
          {{ 'home.new_arrivals' | t }}
        {%- endif -%}
      </h2>
      {%- unless section.settings.heading_style == 'curated' -%}
      <a href="{{ collection.url | default: routes.all_products_collection_url }}" class="section-link hidden-mobile">
        {{ 'home.view_all' | t }}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      {%- endunless -%}
    </div>

    <div class="products-grid products-grid--4">
      {%- assign shown_count = 0 -%}
      {%- for product in collection.products -%}
        {%- if shown_count >= products_to_show -%}
          {%- break -%}
        {%- endif -%}
        {%- capture listable -%}{% render 'product-is-listable', product: product %}{%- endcapture -%}
        {%- if listable == 'true' -%}
          {% render 'product-card', product_ref: product %}
          {%- assign shown_count = shown_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="section-footer-mobile">
      <a href="{{ collection.url | default: routes.all_products_collection_url }}" class="btn btn--outline btn--pill">
        {{ 'home.view_all' | t }}
      </a>
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Featured products",
  "tag": "section",
  "class": "section-featured-products",
  "settings": [
    {
      "type": "select",
      "id": "heading_style",
      "label": "Heading style",
      "options": [
        { "value": "new_arrivals", "label": "New Arrivals" },
        { "value": "curated", "label": "Curated Selection" }
      ],
      "default": "new_arrivals"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Custom heading (overrides style above)"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
