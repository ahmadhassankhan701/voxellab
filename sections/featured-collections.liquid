{%- liquid
  assign collections_to_show = section.settings.collections_to_show | default: 4
  assign visible_count = 0
-%}

{%- if section.settings.collection_list != blank -%}
  {%- for coll in section.settings.collection_list -%}
    {%- capture visible -%}{% render 'collection-is-visible', collection: coll %}{%- endcapture -%}
    {%- if visible == 'true' -%}
      {%- assign visible_count = visible_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
{%- else -%}
  {%- for coll in collections -%}
    {%- capture visible -%}{% render 'collection-is-visible', collection: coll %}{%- endcapture -%}
    {%- if visible == 'true' -%}
      {%- assign visible_count = visible_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if visible_count > 0 -%}
<section class="section section--collections" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="block-header block-header--center">
      <h2 class="section-title font-display">{{ 'home.browse_collections' | t }}</h2>
      <p class="section-subtitle">{{ 'home.collections_subtitle' | t }}</p>
    </div>

    <div class="collections-grid">
      {%- assign shown_count = 0 -%}
      {%- if section.settings.collection_list != blank -%}
        {%- for coll in section.settings.collection_list -%}
          {%- if shown_count >= collections_to_show -%}
            {%- break -%}
          {%- endif -%}
          {%- capture visible -%}{% render 'collection-is-visible', collection: coll %}{%- endcapture -%}
          {%- if visible == 'true' -%}
            <a href="{{ coll.url }}" class="collection-card">
              <div class="collection-card__overlay"></div>
              <h3 class="collection-card__title font-display">{{ coll.title }}</h3>
              {%- if coll.featured_image -%}
                {{
                  coll.featured_image
                  | image_url: width: 600
                  | image_tag: class: 'collection-card__image', loading: 'lazy', alt: coll.title
                }}
              {%- elsif coll.products.first.featured_media -%}
                {{
                  coll.products.first.featured_media
                  | image_url: width: 600
                  | image_tag: class: 'collection-card__image', loading: 'lazy', alt: coll.title
                }}
              {%- endif -%}
            </a>
            {%- assign shown_count = shown_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- for coll in collections -%}
          {%- if shown_count >= collections_to_show -%}
            {%- break -%}
          {%- endif -%}
          {%- capture visible -%}{% render 'collection-is-visible', collection: coll %}{%- endcapture -%}
          {%- if visible == 'true' -%}
            <a href="{{ coll.url }}" class="collection-card">
              <div class="collection-card__overlay"></div>
              <h3 class="collection-card__title font-display">{{ coll.title }}</h3>
              {%- if coll.featured_image -%}
                {{
                  coll.featured_image
                  | image_url: width: 600
                  | image_tag: class: 'collection-card__image', loading: 'lazy', alt: coll.title
                }}
              {%- elsif coll.products.first.featured_media -%}
                {{
                  coll.products.first.featured_media
                  | image_url: width: 600
                  | image_tag: class: 'collection-card__image', loading: 'lazy', alt: coll.title
                }}
              {%- endif -%}
            </a>
            {%- assign shown_count = shown_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Featured collections",
  "tag": "section",
  "class": "section-featured-collections",
  "settings": [
    {
      "type": "collection_list",
      "id": "collection_list",
      "label": "Collections",
      "limit": 8
    },
    {
      "type": "range",
      "id": "collections_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Collections to show"
    }
  ],
  "presets": [
    {
      "name": "Featured collections"
    }
  ]
}
{% endschema %}
