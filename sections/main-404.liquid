<section class="page-section not-found-page">
  <div class="container container--narrow not-found">
    <h1 class="not-found__title font-display">{{ '404.title' | t }}</h1>
    <p class="not-found__body">{{ '404.body' | t }}</p>
    <a href="{{ routes.root_url }}" class="btn btn--primary btn--pill">{{ '404.back_home' | t }}</a>
  </div>
</section>

{% schema %}
{
  "name": "404",
  "tag": "section",
  "class": "section-404",
  "settings": []
}
{% endschema %}
