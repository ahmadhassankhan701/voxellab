<!doctype html>
{%- liquid
  assign is_rtl = false
  if request.locale.iso_code == 'ar' or request.locale.iso_code contains 'ar-'
    assign is_rtl = true
  elsif localization.language.iso_code == 'ar'
    assign is_rtl = true
  endif
-%}
<html lang="{{ request.locale.iso_code }}" dir="{% if is_rtl %}rtl{% else %}ltr{% endif %}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#8B5A3C">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags.join(', ') }}{% endif -%}
    {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Outfit:wght@300;400;500;600&family=Reem+Kufi:wght@400;500;600;700&family=Sora:wght@400;600;700&family=Tajawal:wght@300;400;500;700&display=swap" rel="stylesheet">

  {{ content_for_header }}

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <style>
    :root {
      --brand-primary: {{ settings.color_primary }};
      --brand-background: {{ settings.color_background }};
      --brand-foreground: {{ settings.color_foreground }};
      --brand-accent: {{ settings.color_accent }};
    }
  </style>

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</head>

<body class="template-{{ template.name | handle }}">
  <a class="skip-link visually-hidden" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>

  {% sections 'header-group' %}

  <main id="MainContent" class="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}
</body>
</html>
